---
import Base from '../../layouts/Base.astro';
import data from '../../data/case-studies.json';

const cs = data.edtech;
---

<Base title={`${cs.title} - Case Study - Shubham Sharan`} description={cs.subtitle}>
  <section class="page-hero">
    <div class="container">
      <a class="breadcrumb" href="/#work">← {cs.backLabel}</a>
      <div class="tag-row" style="margin-bottom:1.4rem">
        {cs.tags.map((t) => <span class="tag">{t}</span>)}
      </div>
      <span class="eyebrow">{cs.role}</span>
      <h1>{cs.title}</h1>
      <p class="lede">{cs.subtitle}</p>
      <div class="cs-hero-stats">
        {cs.heroStats.map((s) => (
          <div>
            <div class="stat-value" style="font-size:2rem">{s.value}</div>
            <div class="stat-label">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <div class="container">
    <article class="prose">
      {cs.sections.map((section) => (
        <>
          {section.eyebrow && <span class="eyebrow" style="margin-top:2.5rem">{section.eyebrow}</span>}
          <h2 style={section.eyebrow ? 'border-top:none;padding-top:0;margin-top:0.4rem' : ''}>
            {section.heading}
          </h2>
          {section.paragraphs?.map((p) => <p>{p}</p>)}
          {section.features && (
            <div class="feature-grid">
              {section.features.map((f) => (
                <div class="feature-card">
                  <h4>{f.title}</h4>
                  <p>{f.body}</p>
                </div>
              ))}
            </div>
          )}
          {section.list && (
            <ul class="owned-list">
              {section.list.map((item) => <li>{item}</li>)}
            </ul>
          )}
          {section.impactStats && (
            <div class="impact-grid">
              {section.impactStats.map((s) => (
                <div class="impact-card">
                  <div class="stat-value" style="font-size:2.2rem">{s.value}</div>
                  <div class="stat-label">{s.label}</div>
                </div>
              ))}
            </div>
          )}
        </>
      ))}
    </article>
    <nav class="pager">
      <a href="/#work">← Back to work</a>
      <a href="/contact/">Get in touch →</a>
    </nav>
  </div>
</Base>
