---
import Base from '../layouts/Base.astro';
import profile from '../data/profile.json';

const c = profile.contact;
const linkedin = (profile.socials || []).find((s: any) => s.label === 'LinkedIn')?.url;
const topmate = (profile.socials || []).find((s: any) => s.label === 'Topmate')?.url;
---

<Base title={`Contact - ${profile.name}`}>
  <div class="container">
    <div class="contact-wrap">
      <span class="eyebrow">{c.eyebrow}</span>
      <h1>{c.title}</h1>
      <p class="lede">{c.subtitle}</p>

      <form class="contact-form" method="POST" action={`https://formsubmit.co/${c.email}`}>
        <input type="hidden" name="_subject" value="New message from shubhamsharan.co" />
        <input type="hidden" name="_template" value="table" />
        <input type="hidden" name="_captcha" value="false" />
        <input type="text" name="_honey" style="display:none" tabindex="-1" autocomplete="off" />
        <input type="text" name="name" placeholder="Your name" required />
        <input type="email" name="email" placeholder="Your email" required />
        <select name="subject" required>
          <option value="" disabled selected>Select a topic</option>
          {c.topics.map((t) => <option value={t}>{t}</option>)}
        </select>
        <textarea name="message" placeholder="Your message" required></textarea>
        <button class="btn btn-solid" type="submit">Send message</button>
      </form>

      <div class="contact-alt">
        <p><svg class="contact-ico" viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg><a href={`mailto:${c.email}`}>{c.email}</a></p>
        <p><svg class="contact-ico" viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg><a href={`tel:${c.phone.replace(/[^+\d]/g, '')}`}>{c.phone}</a></p>
        <p><svg class="contact-ico" viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M19 3h-1V1h-2v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V8h14v11z"/></svg><a href={profile.calendlyUrl} target="_blank" rel="noopener">Schedule a 30-min call →</a></p>
        {linkedin && <p><svg class="contact-ico" viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg><a href={linkedin} target="_blank" rel="noopener">Connect on LinkedIn →</a></p>}
        {topmate && <p><svg class="contact-ico" viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M20 2H4c-1.1 0-1.99.9-1.99 2L2 22l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2z"/></svg><a href={topmate} target="_blank" rel="noopener">Book a 1:1 on Topmate →</a></p>}
      </div>
    </div>
  </div>
</Base>
