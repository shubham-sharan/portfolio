---
import Base from '../layouts/Base.astro';
import profile from '../data/profile.json';

const c = profile.contact;
---

<Base title={`Contact - ${profile.name}`}>
  <div class="container">
    <div class="contact-wrap">
      <span class="eyebrow">{c.eyebrow}</span>
      <h1>{c.title}</h1>
      <p class="lede">{c.subtitle}</p>

      <form class="contact-form" method="POST" action={`mailto:${c.email}`} enctype="text/plain">
        <input type="text" name="name" placeholder="Your name" required />
        <input type="email" name="email" placeholder="Your email" required />
        <select name="subject" required>
          <option value="" disabled selected>Select a topic</option>
          {c.topics.map((t) => <option value={t}>{t}</option>)}
        </select>
        <textarea name="message" placeholder="Your message" required></textarea>
        <button class="btn btn-solid" type="submit">Send message</button>
      </form>

      <div class="contact-alt">
        <p>Or email me directly at <a href={`mailto:${c.email}`}>{c.email}</a></p>
        <p style="margin-top:1.2rem">You can also find me on:</p>
        <div class="social-row">
          {profile.socials.map((s) => <a class="text-link" href={s.url}>{s.label}</a>)}
        </div>
      </div>
    </div>
  </div>
</Base>
