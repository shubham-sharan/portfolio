---
import Base from '../layouts/Base.astro';
import profile from '../data/profile.json';
import work from '../data/work.json';
import caseStudies from '../data/case-studies.json';
import skills from '../data/skills.json';
import testimonials from '../data/testimonials.json';
import frameworksIndex from '../data/frameworks-index.json';
import lifecycle from '../data/lifecycle.json';

const current = work.items[0]; // Huzzle - the "Now" panel
const acts = ['The Operator', 'The Founder', 'The Builder'];
const [featuredCase, ...otherCases] = caseStudies.cards;

const roundCount = Object.keys(
  import.meta.glob('../data/interview-rounds/*.json')
).length;
const conceptCount = frameworksIndex.concepts.length;
const stageCount = lifecycle.stages.length;

// Single source of truth: pull each role's impact numbers from its work-page JSON.
const wpModules = import.meta.glob('../data/work-pages/*.json', { eager: true });
const impactBySlug: Record<string, any[]> = {};
for (const m of Object.values(wpModules) as any[]) {
  const p = m.default ?? m;
  if (p.heroStats) impactBySlug[p.slug] = p.heroStats;
}
---

<Base>
  <!-- HERO: split layout - story left, "Now" panel right -->
  <section class="hero">
    <div class="container hero-grid">
      <div>
        <span class="eyebrow">{profile.eyebrow}</span>
        <h1>{profile.heroTitle}</h1>
        {profile.heroTagline && <p class="hero-tagline">{profile.heroTagline}</p>}
        {profile.heroParagraphs.map((p) => <p class="hero-body">{p}</p>)}
        <ul class="hero-points">
          {profile.heroPoints.map((pt) => <li>{pt}</li>)}
        </ul>
        <div class="hero-actions">
          <a class="btn btn-solid" href="#work">See the journey</a>
          <a class="btn btn-ghost" href={profile.resumeUrl} target="_blank" rel="noopener">Download resume</a>
        </div>
      </div>

      <aside class="now-card reveal">
        <span class="now-label"><span class="now-dot"></span> Now</span>
        <p class="now-role">{current.role} · {current.company}</p>
        <p class="now-desc">{current.summary}</p>
        <ul class="now-stats">
          {profile.stats.map((s) => (
            <li>
              <span>{s.label}</span>
              <span class="stat-value">{s.value}</span>
            </li>
          ))}
        </ul>
      </aside>
    </div>
  </section>

  <!-- CAPABILITY STRIP -->
  <div class="cap-strip" aria-label="Capabilities">
    <div class="container">
      <span class="cap-label">What I do</span>
      {skills.whatIDo.items.map((s) => <span class="cap-chip">{s}</span>)}
    </div>
  </div>

  <!-- CAREER: three acts, told as a timeline -->
  <section id="work">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">{work.eyebrow}</span>
        <h2>Twelve years, three acts</h2>
        <p class="lede">
          Engineer → founder → product leader. {work.subtitle} Each act taught a different seat at
          the table.
        </p>
      </div>

      <div class="timeline">
        {work.items.map((item, i) => (
          <article class="timeline-item reveal">
            <span class="timeline-act">Act {item.index} - {acts[i] ?? item.descriptor}</span>
            <h3>{item.company} <em style="font-style:normal;color:var(--muted)">· {item.descriptor}</em></h3>
            <p class="timeline-role">{item.role}</p>
            <p class="work-summary">{item.summary}</p>
            <div class="tag-row">
              {item.tags.map((t) => <span class="tag">{t}</span>)}
            </div>
            <div class="work-stats">
              {item.stats.map((s) => (
                <div class="work-stat">
                  <div class="stat-value">{s.value}</div>
                  <div class="stat-label">{s.label}</div>
                </div>
              ))}
            </div>
            {impactBySlug[item.slug] && (
              <div class="impact-block">
                <p class="toolkit-label">{item.impactLabel}</p>
                <div class="impact-cards">
                  {impactBySlug[item.slug].map((m) => (
                    <div class="impact-stat">
                      {m.dir && m.dir !== 'flat' && (
                        <span class={`impact-arrow ${m.dir}`}>{m.dir === 'up' ? '▲' : '▼'}</span>
                      )}
                      <span class="impact-value">{m.value}</span>
                      <span class="impact-cap">{m.label}</span>
                    </div>
                  ))}
                </div>
              </div>
            )}
            <p style="margin-top:1.3rem;display:flex;gap:1.6rem;flex-wrap:wrap">
              <a class="text-link" href={`/work/${item.slug}/`}>Explore the work →</a>
              {item.productUrl && (
                <a class="text-link" href={item.productUrl} target="_blank" rel="noopener">
                  Visit {item.company.toLowerCase()}.com ↗
                </a>
              )}
            </p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CASE STUDIES: one featured, rest compact -->
  <section id="case-studies" class="rule" style="background: var(--bg-soft)">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">{caseStudies.eyebrow}</span>
        <h2>How I think, in public</h2>
        <p class="lede">{caseStudies.subtitle}</p>
      </div>

      <a class="case-feature reveal" href={featuredCase.href}>
        <div class="case-feature-main">
          <span class="case-kicker">Featured · {featuredCase.kicker}</span>
          <h3>{featuredCase.title}</h3>
          <p>{caseStudies.getYourGuide.summary}</p>
          <span class="text-link">Read the full case study →</span>
        </div>
        <div class="case-feature-side">
          <span class="meta-line">{caseStudies.getYourGuide.meta}</span>
          <div class="tag-row">
            {featuredCase.tags.map((t) => <span class="tag">{t}</span>)}
          </div>
        </div>
      </a>

      <div class="case-mini-grid">
        {otherCases.map((c) => (
          <a class="case-card reveal" href={c.href}>
            <span class="case-kicker">{c.kicker}</span>
            <h3>{c.title}</h3>
            <div class="tag-row">
              {c.tags.map((t) => <span class="tag">{t}</span>)}
            </div>
            <span class="text-link">Read the full case study →</span>
          </a>
        ))}
      </div>
      <p class="case-note">{caseStudies.footnote}</p>
    </div>
  </section>

  <!-- RESOURCES: the thinking library (frameworks, prep, lifecycle) -->
  <section id="resources" class="rule">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">The PM Library</span>
        <h2>Lessons from building products</h2>
        <p class="lede">
          A public library of the frameworks, lifecycle concepts, and interview guides I've written
          - the working vocabulary behind the decisions.
        </p>
      </div>
      <div class="resource-grid">
        <a class="resource-card reveal" href="/frameworks/">
          <div class="resource-count">{conceptCount}</div>
          <h3>Framework references</h3>
          <p>A searchable index of every concept I use - JTBD, problem statements, opportunity trees, and more.</p>
          <span class="text-link">Browse the library →</span>
        </a>
        <a class="resource-card reveal" href="/product-lifecycle/">
          <div class="resource-count">{stageCount}</div>
          <h3>Lifecycle stages</h3>
          <p>Conceive to Retire - how I think about product work at every stage, and the concepts each demands.</p>
          <span class="text-link">See the lifecycle →</span>
        </a>
        <a class="resource-card reveal" href="/interview-rounds/">
          <div class="resource-count">{roundCount}</div>
          <h3>Interview playbooks</h3>
          <p>The guides I share with PMs I mentor - what each round really tests, from someone who has sat on both sides of the table.</p>
          <span class="text-link">Read the playbooks →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- TOOLKIT: card grid -->
  <section id="toolkit" class="rule" style="background: var(--bg-soft)">
    <div class="container">
      <div class="toolkit-head">
        <span class="eyebrow">{skills.eyebrow}</span>
        <h2 class="toolkit-title">{skills.title}</h2>
        <p class="lede">{skills.subtitle}</p>
      </div>
      <div class="tk-cards">
        <article class="tk-card">
          <div class="tk-card-head"><span class="tk-num">01</span>{skills.tools.label}</div>
          <div class="chip-row">
            {skills.tools.items.map((s) => <span class="chip">{s}</span>)}
          </div>
        </article>
        <article class="tk-card">
          <div class="tk-card-head"><span class="tk-num">02</span>{skills.growth.label}</div>
          <ul class="cert-list">
            {skills.growth.items.map((g) => (
              <li>
                <span class="cert-name">{g.name}</span>
                <span class="cert-issuer">{g.status}</span>
              </li>
            ))}
          </ul>
        </article>
      </div>
    </div>
  </section>

  <!-- VOICES: all testimonials as boxed cards -->
  <section class="rule">
    <div class="container">
      <div class="section-head" style="text-align:center">
        <span class="eyebrow">{testimonials.eyebrow}</span>
        <h2>{testimonials.title}</h2>
      </div>

      <div class="quote-grid-3">
        {testimonials.items.map((t) => (
          <figure class="quote-card reveal">
            <blockquote>{t.quote}</blockquote>
            <figcaption class="quote-person">
              <span class="avatar">{t.initials}</span>
              <span>
                <strong>{t.name}</strong>
                <span>{t.role}</span>
              </span>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- ABOUT: the route IS the layout - intro → four chapters → conviction → close -->
  <section id="about" class="rule" style="background: var(--bg-soft)">
    <div class="container">
      <div class="section-head" style="margin-bottom:2.8rem">
        <span class="eyebrow">{profile.about.eyebrow}</span>
        <h2>{profile.about.title}</h2>
        <p class="lede">{profile.about.intro}</p>
      </div>

      <div class="chapter-grid">
        {profile.about.chapters.map((c) => (
          <article class="chapter reveal">
            <span class="chapter-step">{c.step}</span>
            <h3>{c.role}</h3>
            <p class="chapter-company">{c.company}</p>
            <p class="chapter-lesson">{c.lesson}</p>
          </article>
        ))}
      </div>

      <figure class="conviction reveal">
        <blockquote>“{profile.about.conviction}”</blockquote>
      </figure>

      <div class="about-close">
        <p>{profile.about.outro}</p>
        <a class="text-link" href="/contact/">Let's connect →</a>
      </div>
    </div>
  </section>

  <!-- CTA: split sign-off - statement left, actions right -->
  <section class="cta-band">
    <div class="container cta-grid">
      <div>
        <span class="eyebrow">Next step</span>
        <h2>{profile.cta.title}</h2>
        <p>{profile.cta.subtitle}</p>
      </div>
      <div class="cta-side">
        <a class="btn btn-solid" href="/contact/">Get in touch</a>
        <a class="btn btn-ghost" href={profile.resumeUrl} target="_blank" rel="noopener">Download resume</a>
        {profile.socials.map((s) => (
          <a class="text-link cta-social" href={s.url} target="_blank" rel="noopener">{s.label} ↗</a>
        ))}
      </div>
    </div>
  </section>
</Base>
